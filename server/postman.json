{
  "info": {
    "name": "PRINK Shopify Integration API",
    "description": "Collection of API endpoints to test the Shopify OAuth integration, Webhooks, and REST endpoints for PRINK.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "OAuth",
      "item": [
        {
          "name": "Initiate OAuth Flow",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/api/shopify/auth?shop=prink-in.myshopify.com",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "shopify", "auth"],
              "query": [
                {
                  "key": "shop",
                  "value": "prink-in.myshopify.com"
                }
              ]
            },
            "description": "Generates the Shopify OAuth redirection URL to trigger store authorization."
          }
        },
        {
          "name": "OAuth Callback URL",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/api/shopify/callback?shop=prink-in.myshopify.com&code=auth_code_here&state=security_state_here&hmac=shopify_hmac_here",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "shopify", "callback"],
              "query": [
                {
                  "key": "shop",
                  "value": "prink-in.myshopify.com"
                },
                {
                  "key": "code",
                  "value": "auth_code_here"
                },
                {
                  "key": "state",
                  "value": "security_state_here"
                },
                {
                  "key": "hmac",
                  "value": "shopify_hmac_here"
                }
              ]
            },
            "description": "Callback endpoint called by Shopify after user approves app access."
          }
        }
      ]
    },
    {
      "name": "Admin REST API Cache & Proxies",
      "item": [
