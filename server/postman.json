    {
      "name": "Webhooks Recipient",
      "item": [
        {
          "name": "Incoming Order Created Webhook",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-shopify-topic",
                "value": "orders/create",
                "type": "text"
              },
              {
                "key": "x-shopify-shop-domain",
                "value": "prink-in.myshopify.com",
                "type": "text"
              },
              {
                "key": "x-shopify-webhook-id",
                "value": "web_12345678",
                "type": "text"
              },
              {
                "key": "x-shopify-hmac-sha256",
                "value": "calculated_hmac_here",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": 888299102,\n  \"email\": \"customer@example.com\",\n  \"order_number\": 1049,\n  \"financial_status\": \"paid\",\n  \"total_price\": \"59.99\",\n  \"currency\": \"USD\",\n  \"line_items\": [\n    {\n      \"id\": 9912028,\n      \"title\": \"Canvas Print Wrap\",\n      \"quantity\": 1,\n      \"price\": \"59.99\",\n      \"sku\": \"CANVAS-12X16\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/webhooks/shopify",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "webhooks", "shopify"]
            }
          }
        }
      ]
    }
